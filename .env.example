# =========================================
# 🌍 Environment
# =========================================
APP_ENV=dev

# =========================================
# 📦 Redis Configuration
# =========================================
# Format: host:port
REDIS_URL=localhost:6379

# =========================================
# 🧵 Worker Configuration
# =========================================
# Number of concurrent workers
WORKER_COUNT=3

# =========================================
# 🔁 Retry Configuration
# =========================================
# Max retry attempts for failed events
MAX_RETRIES=3

# Base backoff in seconds (exponential)
# Example: 1 → 2 → 4 seconds
BACKOFF_SECONDS=1

# =========================================
# 📬 Dead Letter Queue (DLQ)
# =========================================
# Maximum number of failed events to keep
DLQ_SIZE=100

# =========================================
# 🛑 Rate Limiter Configuration
# =========================================
# Max requests allowed
RATE_LIMIT=5

# Time window (in seconds)
RATE_WINDOW_SECONDS=10

# =========================================
# ⏱️ Timeout Configuration
# =========================================
# HTTP request timeout (seconds)
HTTP_TIMEOUT=5

# Redis connection timeout (seconds)
REDIS_TIMEOUT=2

LOG_LEVEL=info

# =========================================
# 🔐 Secrets (DO NOT COMMIT REAL VALUES)
# =========================================
# Example (optional for future use)
# REDIS_PASSWORD=your-secret-password
# API_KEY=your-api-key